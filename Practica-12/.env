# ================================================================
# PRÁCTICA 12 - Variables de Configuración del Servidor de Correo
# NUNCA subas este archivo a un repositorio público (git)
# ================================================================

# --- Identidad del servidor de correo ---
DOMAINNAME=reprobados.com
POSTMASTER_ADDRESS=postmaster@reprobados.com

# --- Módulos de seguridad ---
ENABLE_RSPAMD=1           # Filtro de spam moderno con análisis heurístico
ENABLE_FAIL2BAN=1         # Bloqueo automático de IPs tras intentos fallidos
ENABLE_OPENDKIM=1         # Firma criptográfica DKIM de correos salientes
ENABLE_OPENDMARC=1        # Política DMARC para combatir spoofing
ENABLE_SPAMASSASSIN=0     # Desactivado (usamos Rspamd como alternativa moderna)

# --- Cifrado TLS/SSL ---
# self-signed: genera un certificado autofirmado automáticamente (para práctica)
# Para producción real, usar: SSL_TYPE=letsencrypt
SSL_TYPE=self-signed
SSL_CERT_PATH=
SSL_KEY_PATH=

# --- Configuración de red Docker ---
# host: permite que el host acceda al contenedor sin NAT
PERMIT_DOCKER=host

# --- Postfix (Agente de Transferencia SMTP) ---
POSTSCREEN_ACTION=enforce
RELAY_HOST=
RELAY_PORT=25
RELAY_USER=
RELAY_PASSWORD=

# --- Dovecot (Agente de Entrega IMAP) ---
DOVECOT_INET_PROTOCOLS=all

# --- Logging y Auditoría ---
LOG_LEVEL=info
POSTFIX_MESSAGE_SIZE_LIMIT=52428800    # Tamaño máximo por mensaje: 50 MB

# --- Fail2ban - Umbrales de bloqueo ---
FAIL2BAN_BLOCKTYPE=drop
